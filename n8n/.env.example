# n8n セルフホスト用 — 環境変数サンプル
# docker-compose.yml の environment または .env に設定

# LINE Developers → Messaging API チャネル
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token_here

# HPのQR・ボタン用（LINE Official Account Manager → 友だち追加 のURL）
# 例: https://lin.ee/AbCdEfGh
LINE_ADD_FRIEND_URL=https://lin.ee/5fsRra0

# 任意: Slack / Discord 等の Incoming Webhook（スタッフ通知）
STAFF_NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# n8n 本体（Railway 例）
# N8N_HOST=n8n-production-96aa.up.railway.app
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://n8n-production-96aa.up.railway.app/

# LINE Webhook URL（LINE Developers に登録するURL）
# https://n8n-production-96aa.up.railway.app/webhook/line-keight
